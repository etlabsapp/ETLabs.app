# Same Supabase project as FlipFeed (or create one). Run the SQL in supabase/migrations/ to create tracked_apps table.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: comma-separated emails allowed to sign in (e.g. you@etlabs.app). If empty, any account can sign in.
ALLOWED_EMAILS=
