# Supabase (required for auth + profile/config)
# Create a project at https://supabase.com and copy these from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Weather widget (get key at https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# --- Optional: bookmarkable “my downloads” page (no FlipFeed login) ---
# Open: /my-downloads?token=YOUR_TOKEN  (keep token secret; bookmark the full URL)
PRIVATE_DOWNLOADS_TOKEN=long-random-string
# App Store Connect API key (.p8 contents, or one line with \n for newlines)
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY=
ASC_VENDOR_NUMBER=
# Numeric Apple ID for one app (App Store Connect → App → App Information). Optional.
ASC_APP_APPLE_ID=
