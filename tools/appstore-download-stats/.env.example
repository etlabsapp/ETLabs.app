# App Store Connect → Users and Access → Integrations → App Store Connect API → Generate Key
# Download the .p8 file once; never commit it.
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8

# Payments and Financial Reports → View vendor numbers (numeric string)
ASC_VENDOR_NUMBER=12345678

# App’s Apple ID from App Store Connect → App Information (numeric). Optional: omit to sum all rows.
ASC_APP_APPLE_ID=1234567890

# For server.py only — long random string; add ?token=... to the URL
STATS_PAGE_SECRET=change-me-to-something-long
